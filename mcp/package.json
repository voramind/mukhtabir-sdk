{
  "name": "@voramind/mukhtabir-mcp",
  "version": "0.1.0",
  "description": "Mukhtabir MCP server",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "mukhtabir-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage",
    "format": "prettier --write \"{src,test}/**/*.ts\" \"*.ts\"",
    "format:check": "prettier --check \"{src,test}/**/*.ts\" \"*.ts\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start:http": "bash ./scripts/start-http.sh",
    "test": "vitest run --exclude test/live-integration.test.ts",
    "test:integration": "vitest run test/live-integration.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.5.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.2.4"
  }
}
